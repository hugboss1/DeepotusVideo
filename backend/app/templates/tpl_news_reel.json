{
  "id": "tpl_news_reel",
  "name": "News Reel — reel + avatar",
  "description": "v1.7 news post: animated news reel on top, HeyGen avatar reading the script at the bottom, brand strip outro. Slots: reel, avatar.",
  "version": 1,
  "canvas": {
    "width": 1080,
    "height": 1920,
    "background_color": "#02060d",
    "fps": 30,
    "duration_s": 12
  },
  "regions": [
    {
      "id": "r_reel",
      "type": "video_slot",
      "x": 0,
      "y": 0,
      "width": 1080,
      "height": 1080,
      "z_index": 0,
      "slot_name": "reel",
      "slot_label": "News reel (illustration)",
      "default_provider": "seedance",
      "fit": "cover",
      "audio_volume": 0.0
    },
    {
      "id": "r_avatar",
      "type": "video_slot",
      "x": 0,
      "y": 1080,
      "width": 1080,
      "height": 680,
      "z_index": 0,
      "slot_name": "avatar",
      "slot_label": "HeyGen avatar (reads the script)",
      "default_provider": "heygen",
      "fit": "cover_top",
      "audio_volume": 1.0
    },
    {
      "id": "r_sep",
      "type": "separator",
      "x": 0,
      "y": 1076,
      "width": 1080,
      "height": 8,
      "z_index": 2,
      "color": "#00e5ff"
    },
    {
      "id": "r_brand",
      "type": "brand_strip",
      "x": 0,
      "y": 1760,
      "width": 1080,
      "height": 160,
      "z_index": 3,
      "background_color": "#02060d",
      "items": [
        { "type": "mark", "src": "marks/wordmark_cyan.png", "x": 64, "y": 48, "scale": 0.5 },
        { "type": "text", "text": "$DEEPOTUS", "x": 820, "y": 60, "font": "JetBrains Mono", "size": 30, "color": "#00e5ff", "weight": 700 }
      ]
    }
  ],
  "transitions": [
    { "type": "fade_in", "duration_s": 0.4, "target": "r_reel" },
    { "type": "fade_in", "duration_s": 0.5, "target": "r_avatar", "delay_s": 0.3 }
  ],
  "audio": {
    "master_track": "from_slot:avatar",
    "tail_pad_s": 0.8,
    "background_music": null,
    "ducking_db": -18,
    "fade_in_s": 0.3,
    "fade_out_s": 0.6,
    "loudness_target_lufs": -14
  },
  "metadata": {
    "tags": ["news", "reel", "post"],
    "target_platforms": ["instagram_reels", "x", "youtube_shorts"],
    "voice_mode_hint": "alpha"
  }
}
