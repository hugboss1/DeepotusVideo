# ============================================================
# DEEPOTUS VIDEO GEN -- Environment Configuration
# ============================================================
# This file is automatically copied to .env during install.
# Edit .env (NOT this file) to add your keys and customize paths.
# ============================================================

# --- fal.ai (Seedance 2.0 / image-to-video) -- REQUIRED ---
# Get your key: https://fal.ai/dashboard/keys
FAL_KEY=

# --- ElevenLabs (voiceover FR/EN) -- OPTIONAL ---
# Leave empty to skip voiceover. Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_EN=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID_FR=ThT5KcBeYPX3keUQqHPh

# --- HeyGen (avatar videos + composition) -- OPTIONAL, REQUIRED for v1.4 HeyGen features ---
# Leave empty to disable HeyGen provider. Get key: https://app.heygen.com/api (Settings -> API)
# Format: sk_V2_hgu_... (paste your full key)
# Pricing: pay-as-you-go. Avatar V ~6 credits/min. Budget $5 min top-up.
# IMPORTANT: after pasting your real key here, NEVER commit this .env file.
HEYGEN_API_KEY=

# ============================================================
# PATHS -- Where your images live and outputs are saved
# ============================================================
# DEFAULT BEHAVIOR: paths below are relative to the project root.
# The folders will be auto-created on first run.
#
# TO USE EXTERNAL FOLDERS (e.g. shared with other tools), uncomment
# and set absolute paths. Use forward slashes "/" or double "\\".
# DO NOT use single backslashes "\" -- they will break.
#
# Examples for external paths:
#   IMAGES_FOLDER=C:/Users/olivi/X-content/images
#   IMAGES_FOLDER=D:/MyContent/deepotus/images
#   IMAGES_FOLDER=//NAS/Shared/deepotus-images       (network share)
# ============================================================

IMAGES_FOLDER=./assets/images
OUTPUTS_FOLDER=./assets/outputs

# --- Database (SQLite, auto-created in backend/) ---
DATABASE_URL=sqlite+aiosqlite:///./deepotus.db

# --- Server ---
HOST=127.0.0.1
PORT=8765

# --- Pipeline defaults (Seedance 2.0) ---
DEFAULT_VIDEO_DURATION=5     # 5 or 10 seconds
DEFAULT_ASPECT_RATIO=9:16    # 9:16 vertical | 1:1 square | 16:9 horizontal
DEFAULT_RESOLUTION=1080p     # 1080p or 720p
DEFAULT_LANGUAGE=EN          # EN or FR
